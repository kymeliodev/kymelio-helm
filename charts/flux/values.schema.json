{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 0
    },
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": { "type": "string" }
      }
    },
    "service": {
      "type": "object",
      "required": ["type", "ports"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "ports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "port"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "targetPort": {
                "type": ["string", "integer"]
              }
            }
          }
        }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "resources": { "type": "object" },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
