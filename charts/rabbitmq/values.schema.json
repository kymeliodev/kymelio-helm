{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 0
    },
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": { "type": "string" }
      }
    },
    "service": {
      "type": "object",
      "required": ["type", "amqp", "management"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "amqp": {
          "type": "object",
          "required": ["port"],
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "portName": { "type": "string" }
          }
        },
        "management": {
          "type": "object",
          "required": ["port"],
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "portName": { "type": "string" }
          }
        }
      }
    },
    "resources": { "type": "object" },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
